# Copy this file to ".env" and adjust as needed.

# Port the server listens on
PORT=3000

# Admin panel credentials (Step 3 auth). CHANGE THESE.
ADMIN_USER=change-me
ADMIN_PASSWORD=change-me-please

# Secret used to sign admin session tokens (Step 3). CHANGE THIS.
SESSION_SECRET=please-change-this-to-a-long-random-string

# Optional: override the SQLite database file location
# DB_PATH=./server/db/artizia.db

# Max image dimension (px) for server-side resize on upload (Step 3)
UPLOAD_MAX_DIM=1500

# Instagram feed (homepage). Leave empty and the feed section simply does not render.
# To get a token: make @artizia_by_marudhar a Business/Creator account, link it to a
# Facebook Page, create a Meta app with "Instagram Basic Display", then generate a
# long-lived token. The server refreshes it automatically before it expires.
IG_ACCESS_TOKEN=
